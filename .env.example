GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_OAUTH_REDIRECT_URI=https://your-domain.com/auth/callback
DATABASE_URL=sqlite:///./app.db
ENCRYPTION_KEY=your_encryption_key
SESSION_SECRET=your_session_secret
FRONTEND_ORIGIN=http://localhost:3000
BACKEND_ORIGIN=https://your-backend-domain.com
WEBHOOK_URL=https://your-backend-domain.com/webhooks/github
GITHUB_RUNNER_PAT=your_github_personal_access_token
GITHUB_RUNNER_LABELS=blazeci-small